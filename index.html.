                    <h3>👷 ${l.name}</h3>
                    <div class="info">📞 ${l.phone}</div>
                    <div class="info">📍 ${l.location}</div>
                    <div class="info">💼 ${l.type}</div>
                    <div class="info">💰 ₹${l.wage}/દિવસ</div>
