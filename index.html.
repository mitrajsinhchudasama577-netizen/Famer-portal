        // ===== BUDGET =====
        function calculateBudget() {
            const crop = document.getElementById('budgetCrop').value;
            const land = parseFloat(document.getElementById('budgetLand').value) || 0;

            if (!crop || land === 0) {
                alert('પાક અને જમીન ભરો');
                return;
            }

            const costs = {
                cotton: 45000,
                bajri: 22000,
                groundnut: 55000,
                wheat: 35000
            };

            const costPerAcre = costs[crop] || 0;
            const totalCost = costPerAcre * land;
            const expectedIncome = totalCost * 1.5;
            const profit = expectedIncome - totalCost;

            document.getElementById('budgetResult').style.display = 'block';
            document.getElementById('totalCost').textContent = '₹' + totalCost.toLocaleString('en-IN');
            document.getElementById('expectedIncome').textContent = '₹' + expectedIncome.toLocaleString('en-IN');
            document.getElementById('profit').textContent = '₹' + profit.toLocaleString('en-IN');
        }

        // ===== FARMER =====
        document.getElementById('farmerForm')?.addEventListener('submit', (e) => {
            e.preventDefault();
            DATA.farmers.unshift({
                id: Date.now(),
                name: document.getElementById('farmerName').value,
                phone: document.getElementById('farmerPhone').value,
                location: document.getElementById('farmerLocation').value,
                land: document.getElementById('farmerLand').value,
                crop: document.getElementById('farmerCrop').value
            });
            saveData();
            showMsg('contactSuccess');
            e.target.reset();
            displayFarmers();
        });

        function displayFarmers() {
            const list = document.getElementById('farmersList');
            if (DATA.farmers.length === 0) {
                list.innerHTML = '<div class="empty">હજી કોણ નોંધાયો નથી</div>';
                return;
            }
            list.innerHTML = DATA.farmers.map(f => `
                <div class="card">
                    <h3>🌾 ${f.name}</h3>
                    <div class="info">📞 ${f.phone}</div>
                    <div class="info">📍 ${f.location}</div>
                    <div class="info">🚜 ${f.land} એકર | 🌱 ${f.crop}</div>
                    <span class="badge">ખેડૂત</span>
                    <button class="delete-btn" onclick="deleteFarmer(${f.id})">Delete</button>
                </div>
            `).join('');
        }

        function deleteFarmer(id) {
            DATA.farmers = DATA.farmers.filter(f => f.id !== id);
            saveData();
            displayFarmers();
        }

