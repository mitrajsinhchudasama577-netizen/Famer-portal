    <script>
        // ===== AUTHENTICATION SYSTEM =====
        const USERS_KEY = 'farmerPortalUsers';
        const SESSION_KEY = 'farmerPortalSession';

        function getUsersFromStorage() {
            const users = localStorage.getItem(USERS_KEY);
            return users ? JSON.parse(users) : {};
        }

        function saveUsersToStorage(users) {
            localStorage.setItem(USERS_KEY, JSON.stringify(users));
        }

        function setSession(username) {
            localStorage.setItem(SESSION_KEY, username);
        }

        function getSession() {
            return localStorage.getItem(SESSION_KEY);
        }

        function logout() {
            localStorage.removeItem(SESSION_KEY);
            location.reload();
        }

        // ===== LOGIN =====
        document.getElementById('userLogin').addEventListener('submit', (e) => {
            e.preventDefault();
            const username = document.getElementById('loginUsername').value;
            const password = document.getElementById('loginPassword').value;
            const users = getUsersFromStorage();

            if (users[username] && users[username] === password) {
                setSession(username);
                showMainWebsite();
                document.getElementById('loginError').style.display = 'none';
            } else {
                document.getElementById('loginError').style.display = 'block';
                document.getElementById('loginError').textContent = '❌ Username અથવા Password ખોટો છે!';
            }
        });

        // ===== SIGNUP =====
        document.getElementById('userSignup').addEventListener('submit', (e) => {
            e.preventDefault();
            const username = document.getElementById('signupUsername').value;
            const password = document.getElementById('signupPassword').value;
            const confirm = document.getElementById('confirmPassword').value;
            const users = getUsersFromStorage();

            if (password !== confirm) {
                alert('❌ Password match નથી કરતા!');
                return;
            }

            if (users[username]) {
                alert('❌ આ username પહલેથી છે!');
                return;
            }

            users[username] = password;
            saveUsersToStorage(users);
            document.getElementById('signupSuccess').style.display = 'block';
            document.getElementById('signupSuccess').textContent = '✅ Register સફળ! હવે Login કરો';
            setTimeout(() => {
                toggleSignup();
                document.getElementById('signupSuccess').style.display = 'none';
            }, 2000);
        });

        function toggleSignup() {
            document.getElementById('loginForm').style.display = 
                document.getElementById('loginForm').style.display === 'none' ? 'block' : 'none';
            document.getElementById('signupForm').style.display = 
                document.getElementById('signupForm').style.display === 'none' ? 'block' : 'none';
        }

        function showMainWebsite() {
            document.getElementById('loginPage').style.display = 'none';
            document.getElementById('mainContent').style.display = 'block';
            document.querySelector('.logout-btn').style.display = 'block';
        }

        // ===== CHECK SESSION ON LOAD =====
        window.addEventListener('load', () => {
            const session = getSession();
            if (session) {
                showMainWebsite();
            } else {
                document.getElementById('mainContent').style.display = 'none';
            }
        });

        // ===== EXISTING DATA SYSTEM =====
        const DATA = {
            farmers: [],
            laborers: [],
            marketplace: []
        };

        function saveData() {
            localStorage.setItem('farmerData', JSON.stringify(DATA));
        }

        function loadData() {
            const saved = localStorage.getItem('farmerData');
            if (saved) {
                Object.assign(DATA, JSON.parse(saved));
            }
        }

        // ===== UI =====
        function showSection(id) {
            document.querySelectorAll('.content-section').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.nav-btn').forEach(el => el.classList.remove('active'));
            document.getElementById(id).classList.add('active');
            event.target.classList.add('active');
        }

