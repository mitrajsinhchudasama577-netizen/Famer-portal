                    <button class="delete-btn" onclick="deleteMarket(${m.id})">Delete</button>
                </div>
            `).join('');
        }

        function deleteMarket(id) {
            DATA.marketplace = DATA.marketplace.filter(m => m.id !== id);
            saveData();
